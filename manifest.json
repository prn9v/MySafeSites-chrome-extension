{
  "manifest_version": 3,
  "name": "MySafeSites Blocker",
  "version": "1.1.0",
  "description": "Blocks distracting sites and detects phishing/malicious URLs using AI.",

  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],

  "host_permissions": [
    "*://*/*",
    "https://my-safe-sites-website-blocker.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js":      ["content.js"],
      "run_at":  "document_idle"
    }
  ],

  "declarative_net_request": {
    "rule_resources": []
  },

  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "icons/*"],
      "matches":   ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}